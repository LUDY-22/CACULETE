{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user with role and store access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "cashier"] },
        "storeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "storeId"]
    },
    "Product": {
      "title": "Product",
      "description": "Store product details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "supplierId": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "salePrice": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "barcode": { "type": "string" },
        "imageUrl": { "type": "string" },
        "storeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "salePrice", "stock", "storeId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "cashierId": { "type": "string" },
        "storeId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "storeId", "timestamp"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Product supplier details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "storeId": { "type": "string" }
      },
      "required": ["name", "storeId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Financial expense record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "storeId": { "type": "string" }
      },
      "required": ["description", "amount", "date", "storeId"]
    },
    "Log": {
      "title": "Log",
      "description": "Audit log for system actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "storeId": { "type": "string" }
      },
      "required": ["userId", "action", "timestamp", "storeId"]
    },
    "StoreSettings": {
      "title": "StoreSettings",
      "description": "Customizable store settings like receipt header and footer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "receiptHeader": { "type": "string" },
        "receiptFooter": { "type": "string" },
        "nif": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["storeId"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles and roles." },
    "products": { "schema": "Product", "description": "Inventory products." },
    "sales": { "schema": "Sale", "description": "Sales history." },
    "suppliers": { "schema": "Supplier", "description": "Supplier list." },
    "expenses": { "schema": "Expense", "description": "Expense records." },
    "logs": { "schema": "Log", "description": "Audit trail." },
    "settings": { "schema": "StoreSettings", "description": "Store-specific configurations." }
  }
}
